node_modules/
*.log
.DS_Store

# Build outputs are large; default to ignoring. Comment these out if shipping
# small sample data in repo for testing (open decision #2).
data/
# Repertoire-filtered output of analyzer/filter-data.js — by default published
# instead of ./data when running with --source-dir. Same gitignore rationale.
data-filtered/

# R2 credentials — alongside data dir, never committed.
.env.r2

# fetch-deltas resumable checkpoint dirs (named <output>.state by default).
*.pgn.state/
*.state/

# ── Capacitor (native build variant) ──────────────────────────────────────
# Assembled web root (tools/build-www.js output) — regenerated on every build.
www/
# Native project — generated by `npx cap add android`, fully reproducible from
# capacitor.config.json. Keep it out of the repo (large, and contains no source
# of truth). Native customizations (icons/splash) are regenerated via
# @capacitor/assets; the signing keystore must NEVER be committed.
android/
ios/
# Android signing key — keep well away from git.
*.keystore
*.jks
